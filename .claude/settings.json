{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Write",
      "Edit",
      "Bash(git *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(test *)"
    ],
    "additionalDirectories": [
      "../../Civia/rag-civia-mandate-service"
    ]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "0"
  }
}
